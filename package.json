{
  "name": "@volta-oss/proposal-brief-builder",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "Turn messy discovery notes into a clean grant proposal brief before anyone writes prose.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "test:python": "PYTHONPATH=backend/python python3 -m unittest discover -s backend/python/tests",
    "test:backend": "npm run test:python",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/proposal-brief-builder:local .",
    "docker:run": "docker compose up --build",
    "serve:python": "PYTHONPATH=backend/python python3 -m proposal_brief_builder_backend.server"
  },
  "keywords": [
    "digital-equity",
    "finance-grants",
    "local-first",
    "oss",
    "release",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/proposal-brief-builder.git"
  },
  "homepage": "https://volta-npo.github.io/proposal-brief-builder/",
  "bugs": {
    "url": "https://github.com/volta-npo/proposal-brief-builder/issues"
  },
  "author": "Volta Open Source <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
